# llm-gateway environment configuration
# Copy this file to .env and fill in your values.

# ── Gateway Authentication ────────────────────────────────────────
# Comma-separated list of API keys that clients must provide via
# Authorization: Bearer <key>. Leave empty to disable auth (dev mode).
GATEWAY_API_KEYS=

# ── Provider API Keys ────────────────────────────────────────────
# The gateway injects these into upstream requests, replacing the
# client's key. This keeps real provider credentials server-side.
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Rate Limiting ────────────────────────────────────────────────
# Configured in envoy.yaml. Default: 100 requests/minute per client.
# To change, edit the token_bucket section in envoy/envoy.yaml.
